# VideoShortsAgent 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ── LLM 配置 ──
# 通义千问 API Key（必需）
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-你的API密钥

# LLM API 地址（支持任何 OpenAI 兼容 API）
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# 本地 Ollama: http://localhost:11434/v1
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
# LLM_MODEL=qwen3.5-flash

# 分析专用模型（可选，默认与 LLM_MODEL 相同）
# LLM_ANALYSIS_MODEL=qwen3.5-flash

# 翻译专用模型
# LLM_TRANSLATE_MODEL=qwen-turbo

# ── 转录配置 ──
# Groq API Key（推荐，极速语音转录）
# 获取地址: https://console.groq.com/
GROQ_API_KEY=gsk_你的API密钥

# 转录模式: groq（推荐） / local（本地 faster-whisper）
# TRANSCRIBE_MODE=groq

# ── TTS 配置 ──
# 默认语音角色
# TTS_VOICE=zh-CN-YunxiNeural

# ── Agent 配置 ──
# Agent 最大迭代次数
# MAX_ITERATIONS=10

# 输出视频最大时长（秒）
# MAX_VIDEO_DURATION=65

# ── 服务器配置 ──
# Web UI 端口
# SERVER_PORT=7860

# ── 外部 API（可选，增强功能）──
# Freesound API Key（在线搜索无版权 BGM）
# 获取地址: https://freesound.org/apiv2/apply/
# FREESOUND_API_KEY=你的FreesoundAPIKey

# Pexels API Key（在线搜索高质量配图）
# 获取地址: https://www.pexels.com/api/
# PEXELS_API_KEY=你的PexelsAPIKey